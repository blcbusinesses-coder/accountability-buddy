{
  "expo": {
    "name": "Accountability Buddy",
    "slug": "accountability-buddy",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "accountability-buddy",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a0a"
    },
    "ios": {
      "supportsTablet": false,
      "infoPlist": {
        "NSCameraUsageDescription": "Used to take photos to verify task completion.",
        "NSMicrophoneUsageDescription": "Used to record audio to verify task completion.",
        "NSPhotoLibraryUsageDescription": "Used to pick and save photos to verify task completion.",
        "NSPhotoLibraryAddUsageDescription": "Used to save your result cards to your camera roll."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0a0a0a",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.POST_NOTIFICATIONS"
      ],
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Accountability Buddy to access your photos.",
          "cameraPermission": "Allow Accountability Buddy to use your camera."
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": "Allow Accountability Buddy to use your microphone."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#00E5A0"
        }
      ],
      "expo-media-library"
    ]
  }
}
